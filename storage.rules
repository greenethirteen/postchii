rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Users upload their own logo; logos are publicly readable so they can be
    // embedded in rendered posts.
    match /logos/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Rendered posts are written by the server (admin SDK), readable by anyone
    // with the link.
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
