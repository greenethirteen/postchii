rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each web user owns their profile doc (keyed by auth uid).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Companies are owned via ownerUid.
    match /companies/{id} {
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
                                  && resource.data.ownerUid == request.auth.uid;
    }

    // Content is written by the server (admin SDK bypasses rules);
    // clients may only read their own.
    match /content/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Early-access waitlist: anyone may join (create only), nobody may read back.
    match /waitlist/{id} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 3
                    && request.resource.data.email.size() < 200;
      allow read, update, delete: if false;
    }

    // Telegram link codes: clients create codes for themselves only.
    // The bot consumes and deletes them via the admin SDK.
    match /linkCodes/{code} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
