# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Firebase (leave unset to fall back to local SQLite)
# Path to the service account JSON downloaded from Firebase console
FIREBASE_SERVICE_ACCOUNT=
# e.g. your-project-id.firebasestorage.app
FIREBASE_STORAGE_BUCKET=

# Server
PORT=3210

# Local storage overrides (optional)
STORAGE_DIR=
DATABASE_PATH=

# Upload-Post API key (upload-post.com) — enables real social publishing
UPLOAD_POST_API_KEY=
